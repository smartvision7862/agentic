# ── Content Agent OS ───────────────────────────────────────────────
# Copy to .env and fill in. Never commit your real .env.

# Dashboard port (default 3950). Sibling ports — job-scraper 3847,
# google-search 3848, download 3939, hr-finding 3940, maps 3942
PORT=3950

# Max scrape sources fetched in parallel
SCRAPE_CONCURRENCY=5

# ── Scraping ───────────────────────────────────────────────────────
# Firecrawl — scrape any URL / search the web. https://firecrawl.dev
FIRECRAWL_API_KEY=

# ── AI (OpenRouter) ────────────────────────────────────────────────
# One key for GPT, Claude, Gemini, etc. https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Optional: appears on OpenRouter leaderboards
OPENROUTER_SITE_URL=http://localhost:3950
OPENROUTER_SITE_NAME=Content Agent OS

# ── Social scheduling (Zernio) ─────────────────────────────────────
# https://zernio.com — handles Instagram, LinkedIn, X OAuth + publishing
ZERNIO_API_KEY=
# Public base URL of this app (for Zernio OAuth callback + webhooks).
# In local dev use an ngrok/tunnel URL; in prod your real domain.
PUBLIC_BASE_URL=http://localhost:3950
# Optional shared secret to verify Zernio webhook calls
ZERNIO_WEBHOOK_SECRET=

# ── Google / Gmail (HUD dashboard: mail + expense scraping) ────────
# Create OAuth 2.0 credentials at https://console.cloud.google.com/apis/credentials
#   1. Create a project → enable the "Gmail API".
#   2. Configure the OAuth consent screen (External), add your Google account
#      as a Test user, and add scope .../auth/gmail.readonly
#   3. Create an "OAuth client ID" of type "Web application".
#   4. Add this exact Authorized redirect URI:
#        http://localhost:3950/api/gmail/callback
#      (must match GOOGLE_REDIRECT_URI / PUBLIC_BASE_URL below)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional — defaults to ${PUBLIC_BASE_URL}/api/gmail/callback
GOOGLE_REDIRECT_URI=http://localhost:3950/api/gmail/callback

# ── Defaults (all overridable in the dashboard Settings tab) ───────
DEFAULT_FRESHNESS_HOURS=24
OPENROUTER_TEXT_MODEL=anthropic/claude-sonnet-4
OPENROUTER_IMAGE_MODEL=google/gemini-2.5-flash-image
DEFAULT_TIMEZONE=Asia/Kolkata

# ── Optional supplemental news discovery ───────────────────────────
# NEWSDATA_API_KEY=

# ── WhatsApp (Twilio) ─────────────────────────────────────────────
# Required for the WhatsApp webhook integration to verify and reply
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
